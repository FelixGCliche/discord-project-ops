{
  "name": "cloudflare",
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./linear-token-store": "./src/linear-token-store/index.ts",
    "./github-token-store": "./src/github-token-store/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "check": "tsc --noEmit && oxlint && oxfmt",
    "check:type": "tsc --noEmit",
    "check:lint": "oxlint",
    "check:format": "oxfmt --check",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt"
  },
  "dependencies": {
    "core": "workspace:*",
    "jsonc-parser": "3.2.0",
    "linear": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
