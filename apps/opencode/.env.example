OPENCODE_API_KEY=<YOUR_OPENCODE_API_KEY>

OPENCODE_SERVER_HOSTNAME=0.0.0.0
OPENCODE_SERVER_PORT=4096
# HTTP basic auth password for the opencode server. Required -- without it the
# server accepts unauthenticated requests from anything that can reach the port.
OPENCODE_SERVER_PASSWORD=<CHOOSE_A_STRONG_PASSWORD>
