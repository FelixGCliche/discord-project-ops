{
  "name": "discord-project-ops",
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run check:type && oxlint && oxfmt",
    "check:type": "bun run --filter='*' check:type",
    "check:lint": "oxlint",
    "check:format": "oxfmt --check",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt",
    "test:all": "bun test && bun -F opencode test:pipeline",
    "secrets:push": "bun --env-file=packages/cloudflare/.env --env-file=apps/bot/.env --env-file=packages/linear/.env run packages/cloudflare/src/provision-secrets.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/bun": "latest",
    "jsonc-parser": "3.2.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
