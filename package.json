{
  "name": "discord-project-ops",
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run check:type && oxlint && oxfmt",
    "check:type": "bun run --filter='*' check:type",
    "check:lint": "oxlint",
    "check:format": "oxfmt --check",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt",
    "test:all": "bun test && bun -F opencode test:pipeline",
    "secrets:push": "bun run apps/bot/src/secrets/provision.ts",
    "secrets:push:staging": "bun run apps/bot/src/secrets/provision.ts staging",
    "secrets:validate": "bun run apps/bot/src/secrets/validate.ts",
    "secrets:validate:staging": "bun run apps/bot/src/secrets/validate.ts staging",
    "auth:linear": "bun --env-file=packages/linear/.env run apps/bot/src/linear-oauth/generate-authorize-link/index.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/bun": "latest",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
